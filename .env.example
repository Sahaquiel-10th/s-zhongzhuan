NODE_ENV=development
PORT=4173
PUBLIC_BASE_URL=http://localhost:4173
DATABASE_PATH=./data/super-relay.db

# 至少 32 个随机字符，用于登录 Cookie 签名。
SESSION_SECRET=replace-with-a-long-random-secret

# 32 字节 Base64，用于加密数据库里的供应商 API Key。
# 生成命令：openssl rand -base64 32
UPSTREAM_KEY_ENCRYPTION_KEY=

# 首次迁移时创建管理员。生产环境务必修改。
ADMIN_ACCOUNT=admin
ADMIN_PASSWORD=change-me-now

RESERVATION_OUTPUT_TOKENS=2048

# 微信支付 API v3 Native 扫码支付。真实值只放在服务器 .env 中。
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=/app/secrets/wechat/apiclient_key.pem
WECHAT_PAY_PUBLIC_KEY_ID=
WECHAT_PAY_PUBLIC_KEY_PATH=/app/secrets/wechat/wechatpay_public_key.pem
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_NOTIFY_URL=https://your-domain.example/api/pay/wechat/notify
