NODE_ENV=development
PORT=4173
PUBLIC_BASE_URL=http://localhost:4173
DATABASE_PATH=./data/super-relay.db

# 至少 32 个随机字符，用于登录 Cookie 签名。
SESSION_SECRET=replace-with-a-long-random-secret

# 32 字节 Base64，用于加密数据库里的供应商 API Key。
# 生成命令：openssl rand -base64 32
UPSTREAM_KEY_ENCRYPTION_KEY=

# 首次迁移时创建管理员。生产环境务必修改。
ADMIN_ACCOUNT=admin
ADMIN_PASSWORD=change-me-now

RESERVATION_OUTPUT_TOKENS=2048
